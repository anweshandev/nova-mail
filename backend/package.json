{
  "name": "novamail-backend",
  "displayName": "NovaMail Backend",
  "version": "1.0.0",
  "description": "Backend API for NovaMail - Open-source email client with IMAP/SMTP support",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint src/",
    "test": "node --test",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:make": "knex migrate:make"
  },
  "keywords": [
    "email",
    "imap",
    "smtp",
    "mail-client",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "imap": "^0.8.19",
    "imapflow": "^1.2.9",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "mailparser": "^3.9.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "eslint": "^9.9.0"
  }
}
